NODE_ENV=development
PORT=4000
APP_URL=
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://localhost:5173
TELEGRAM_USE_WEBHOOK=false

# Lock backend to one Telegram token only
TELEGRAM_BOT_TOKEN=xxxxxxxx
SINGLE_TELEGRAM_TOKEN_ONLY=true

# NVIDIA-only (locked Telegram runtime)
AI_PROVIDER=nvidia
AI_FORCE_PROVIDER=true
NVIDIA_API_KEY=xxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=moonshotai/kimi-k2.5
OPENROUTER_API_KEY=xxxxxxxx
OPENROUTER_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
DEFAULT_MODEL=moonshotai/kimi-k2.5
OPENROUTER_MODEL=moonshotai/kimi-k2.5
OPENROUTER_TIMEOUT_MS=22000
OPENROUTER_MAX_RETRIES=2
OPENROUTER_RETRY_BASE_DELAY_MS=180

# Media transcription for voice/audio/video (optional)
OPENAI_API_KEY=
STT_BASE_URL=
STT_API_KEY=
STT_MODEL=whisper-1
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_BASE_URL=https://api.assemblyai.com/v2
ASSEMBLYAI_SPEECH_MODEL=universal-2
ASSEMBLYAI_STT_ENABLED=true
ASSEMBLYAI_STT_TIMEOUT_MS=45000
ASSEMBLYAI_POLL_INTERVAL_MS=1800
NVIDIA_STT_ENABLED=false
NVIDIA_STT_BASE_URL=
NVIDIA_STT_MODEL=whisper-1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram_bot?schema=public
REDIS_URL=
REDIS_TIMEOUT_MS=2200
REDIS_ANTI_SPAM_PREFIX=swiftdeploy:antispam
ADMIN_EMAILS=
ADMIN_TELEGRAM_IDS=
MODERATION_AUDIT_FILE=
MODERATION_AUDIT_MAX_ENTRIES=5000
MODERATION_AUDIT_LOG_ALL=false
TELEGRAM_ADMIN_RESTRICTIONS_FILE=

MAX_INPUT_CHARS=12000
MAX_OUTPUT_TOKENS=1800
STREAM_EDIT_INTERVAL_MS=60
STREAM_PREVIEW_MAX_CHARS=1600
MAX_CONTINUATION_ROUNDS=1
TYPEWRITER_FALLBACK_ENABLED=false
TYPEWRITER_CHARS_PER_TICK=160
TYPEWRITER_TICK_MS=4
SIMULATED_STREAM_CHUNK_SIZE=180
SIMULATED_STREAM_DELAY_MS=4
MAX_MODEL_ATTEMPTS=2
MAX_TOOL_ROUNDS=1
FAST_RECENT_CONTEXT_MESSAGES=8

LOG_LEVEL=info

# Email verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_DOMAIN_VALIDATION_STRICT=true
OTP_IN_APP_FALLBACK_ENABLED=false
OTP_SKIP_SMTP_WHEN_FALLBACK=false
