APP_NAME=AI Internet Worker
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
SERVICE_ROLE=api
APP_LOG_LEVEL=INFO

SECRET_KEY=change-this-secret-key
INTERNAL_SERVICE_TOKEN=change-this-internal-token
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=postgresql+psycopg2://worker:worker@postgres:5432/ai_internet_worker
AUTO_APPLY_SCHEMA=true
REDIS_URL=redis://redis:6379/0

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://swift-deploy.in

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

CELERY_TASK_ALWAYS_EAGER=false
CELERY_RESULT_EXPIRES_SECONDS=3600
INPROCESS_SCHEDULER_ENABLED=false
INPROCESS_SCHEDULER_INTERVAL_SECONDS=60
CELERY_WORKER_LOG_LEVEL=info
CELERY_WORKER_CONCURRENCY=2

BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=20000

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
NOTIFICATION_EMAIL_FROM=

TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
