# --- SWIFTDEPLOY AI (NVIDIA-LOCKED TELEGRAM RUNTIME) ---

NODE_ENV=production

# URLs
BASE_URL=https://your-railway-app.up.railway.app
FRONTEND_URL=https://your-frontend-domain.vercel.app
FRONTEND_URLS=https://your-frontend-domain.vercel.app,https://www.your-frontend-domain.com
VITE_API_URL=https://your-railway-app.up.railway.app
BACKEND_API_URL=https://your-railway-app.up.railway.app

# Auth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CALLBACK_URL=https://your-railway-app.up.railway.app/auth/google/callback
SESSION_SECRET=YOUR_VERY_LONG_RANDOM_SESSION_SECRET_HERE_MIN_32_CHARS
JWT_SECRET=YOUR_VERY_LONG_RANDOM_JWT_SECRET_HERE_MIN_32_CHARS

# Telegram
TELEGRAM_BOT_TOKEN=YOUR_PRIMARY_TELEGRAM_BOT_TOKEN
SINGLE_TELEGRAM_TOKEN_ONLY=true

# AI (NVIDIA key + model lock)
AI_PROVIDER=nvidia
AI_FORCE_PROVIDER=true
NVIDIA_API_KEY=YOUR_NVIDIA_API_KEY_HERE
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=moonshotai/kimi-k2.5
HARD_LOCK_NVIDIA_MODEL=true

# Compatibility aliases (must match the NVIDIA values above)
OPENROUTER_API_KEY=YOUR_NVIDIA_API_KEY_HERE
OPENROUTER_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
DEFAULT_MODEL=moonshotai/kimi-k2.5
OPENROUTER_MODEL=moonshotai/kimi-k2.5
FAST_REPLY_MODE=false
SUPER_FAST_RESPONSE_MODE=false

# Optional OCR (recommended for scanned PDFs/images)
OCR_SPACE_API_KEY=YOUR_OCR_SPACE_API_KEY_HERE

# Optional Redis-backed Telegram anti-spam
REDIS_URL=
REDIS_TIMEOUT_MS=2200
REDIS_ANTI_SPAM_PREFIX=swiftdeploy:antispam

# Admin controls
ADMIN_API_KEY=
ADMIN_EMAILS=
ADMIN_TELEGRAM_IDS=
MODERATION_AUDIT_MAX_ENTRIES=5000
MODERATION_AUDIT_LOG_ALL=false

# Server
PORT=3001

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_DOMAIN_VALIDATION_STRICT=true
OTP_IN_APP_FALLBACK_ENABLED=false
OTP_SKIP_SMTP_WHEN_FALLBACK=false

# Discord (optional)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
