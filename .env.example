# =============================================================================
# CLAWCLOUD - COMPLETE ENVIRONMENT VARIABLES
# =============================================================================
# HOW TO USE THIS FILE:
# 1. Copy this file to .env.local in your project root
# 2. Fill in REQUIRED keys first
# 3. Optional keys can be added later to unlock more features
# 4. NEVER commit real secrets to git
# =============================================================================


# =============================================================================
# 1. APP URL
# REQUIRED - set to http://localhost:3000 for local dev
# =============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTJS_URL=http://localhost:3000


# =============================================================================
# 2. SUPABASE - Database + Auth
# REQUIRED - get these from: https://supabase.com
# Steps: Create project -> Settings -> API -> copy URL, anon key, service_role key
# =============================================================================

SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-anon-key

# WARNING: Never expose this key on frontend. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-service-role-key

# Optional: override default table names (leave as-is if unsure)
# SUPABASE_PERSISTENCE_TABLE=research_runs
# SUPABASE_THREADS_TABLE=chat_threads


# =============================================================================
# 3. NVIDIA AI - Core AI / LLM
# REQUIRED - get from: https://build.nvidia.com
# Steps: Sign up (free) -> API Keys -> Generate Key
# =============================================================================

NVIDIA_API_KEY=nvapi-your-key-here

# Base URL (do not change unless using a custom NVIDIA endpoint)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Chat model - default is llama-3.1-8b-instruct (free tier available)
# Other options: meta/llama-3.1-70b-instruct, mistralai/mistral-7b-instruct-v0.3
NVIDIA_CHAT_MODEL=meta/llama-3.1-8b-instruct

# Optional: specialized models (leave blank to use NVIDIA_CHAT_MODEL for all)
NVIDIA_FAST_MODEL=
NVIDIA_REASONING_MODEL=
NVIDIA_CODE_MODEL=
NVIDIA_REPORT_MODEL=

# Embedding model for vector search
NVIDIA_EMBED_MODEL=nvidia/llama-3.2-nemoretriever-300m-embed-v1


# =============================================================================
# 4. SEARCH PROVIDERS - Web Search
# REQUIRED: at least ONE of Tavily or SerpAPI
# Tavily recommended - get from: https://tavily.com
# SerpAPI - get from: https://serpapi.com
# =============================================================================

TAVILY_API_KEY=tvly-your-key-here

# Optional second search provider
SERPAPI_API_KEY=


# =============================================================================
# 5. WEB CRAWLING PROVIDERS - Content Extraction
# Optional - at least one recommended for full research features
# Jina is free and easiest to start with: https://jina.ai
# =============================================================================

JINA_API_KEY=jina_your-key-here
FIRECRAWL_API_KEY=
APIFY_API_TOKEN=
SCRAPERAPI_KEY=
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=


# =============================================================================
# 6. VECTOR DATABASE - Memory / Retrieval
# Optional - enables document retrieval and research memory
# Pinecone recommended: https://pinecone.io
# =============================================================================

PINECONE_API_KEY=
PINECONE_INDEX_NAME=swiftdeploy-ai-assistant
PINECONE_NAMESPACE=research
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Weaviate fallback
WEAVIATE_HOST=
WEAVIATE_API_KEY=
RESEARCH_WEAVIATE_CLASS=ResearchChunk


# =============================================================================
# 7. RERANKING PROVIDERS - Result Quality
# Optional - improves search result quality
# =============================================================================

COHERE_API_KEY=
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3.5-lite


# =============================================================================
# 8. RESEARCH LIMITS - Tuning (optional, defaults are fine)
# =============================================================================

# RESEARCH_MAX_SOURCES=8
# RESEARCH_MAX_SEARCH_RESULTS=24
# RESEARCH_MAX_SEARCH_QUERIES=4
# RESEARCH_MAX_CHUNKS_PER_SOURCE=5
# RESEARCH_RETRIEVE_LIMIT=8


# =============================================================================
# 9. GOOGLE OAUTH - Gmail + Calendar Integration
# REQUIRED for agent features (Gmail/Calendar)
# Steps:
#   1. Go to https://console.cloud.google.com
#   2. Create project -> Enable Gmail API + Google Calendar API
#   3. Credentials -> Create OAuth 2.0 Client ID (Web application)
#   4. Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
#   5. Copy Client ID and Secret below
# =============================================================================

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback


# =============================================================================
# 10. SECURITY SECRETS
# REQUIRED - generate random strings (min 32 chars each)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================

CRON_SECRET=generate-a-random-32-char-string-here
AGENT_SECRET=generate-a-different-random-32-char-string


# =============================================================================
# 11. AGENT SERVER - WhatsApp + Background Tasks
# REQUIRED for WhatsApp features
# For local dev: run "npx tsx agent-server.ts" -> set URL to http://localhost:3001
# For production: deploy agent-server.ts to Railway/Render -> paste URL here
# =============================================================================

AGENT_SERVER_URL=http://localhost:3001
WA_SESSION_DIR=./wa-sessions


# =============================================================================
# 12. PAYMENTS - Razorpay (India / INR)
# REQUIRED for billing features
# =============================================================================

RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
RAZORPAY_PLAN_STARTER_MONTHLY=plan_REPLACE_WITH_REAL_ID
RAZORPAY_PLAN_STARTER_ANNUAL=plan_REPLACE_WITH_REAL_ID
RAZORPAY_PLAN_PRO_MONTHLY=plan_REPLACE_WITH_REAL_ID
RAZORPAY_PLAN_PRO_ANNUAL=plan_REPLACE_WITH_REAL_ID


# =============================================================================
# 13. PAYMENTS - Stripe (International / USD)
# Optional - required for international users paying in USD
# =============================================================================

STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_STARTER_MONTHLY_USD=price_REPLACE_WITH_REAL_ID
STRIPE_PRICE_STARTER_ANNUAL_USD=price_REPLACE_WITH_REAL_ID
STRIPE_PRICE_PRO_MONTHLY_USD=price_REPLACE_WITH_REAL_ID
STRIPE_PRICE_PRO_ANNUAL_USD=price_REPLACE_WITH_REAL_ID

# INR prices via Stripe (optional - use Razorpay for INR instead)
STRIPE_PRICE_STARTER_MONTHLY_INR=
STRIPE_PRICE_STARTER_ANNUAL_INR=
STRIPE_PRICE_PRO_MONTHLY_INR=
STRIPE_PRICE_PRO_ANNUAL_INR=


# =============================================================================
# 14. TELEGRAM BOT - Optional messaging channel
# =============================================================================

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=


# =============================================================================
# 15. FIREBASE - Optional
# Only override these if you are using your own Firebase project
# =============================================================================

# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_APP_ID=
# FIREBASE_MEASUREMENT_ID=


# =============================================================================
# 16. OPENAI - Optional fallback AI provider
# =============================================================================

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini


# =============================================================================
# 17. LANGSMITH - Optional observability / tracing
# =============================================================================

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=swiftdeploy-ai-assistant
