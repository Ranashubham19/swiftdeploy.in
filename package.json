    "link-preview-js": "^3.0.0",
    "mammoth": "^1.12.0",
    "next": "^15.3.0",
    "node-cron": "^4.2.1",
    "openai": "^4.104.0",
    "pdfjs-dist": "^5.5.207",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "youtube-transcript": "^1.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.21",
