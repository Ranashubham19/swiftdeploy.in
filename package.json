  "private": true,
  "description": "SwiftDeploy AI Research Agent",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "agent": "tsx --import ./lib/postgrest-builder-catch.ts agent-server.ts",
