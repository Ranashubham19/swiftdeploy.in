    "verify:setup": "node verify-setup.mjs",
    "smoke:live": "node scripts/live-smoke.mjs",
    "smoke:categories": "node scripts/category-smoke.mjs",
    "qa:live-agent": "tsx scripts/clawcloud-live-api-qa.ts",
    "qa:replay": "tsx scripts/clawcloud-replay-eval.ts",
    "qa:regression": "tsx scripts/clawcloud-whatsapp-regression.ts",
    "qa:benchmark": "tsx scripts/clawcloud-hard-benchmark.ts",
    "qa:scorecard": "tsx scripts/clawcloud-scorecard.ts",
    "qa:canary": "tsx scripts/clawcloud-daily-canary.ts",
    "qa:phase7": "node scripts/clawcloud-phase7-release-gate.mjs",
    "qa:phase11": "node scripts/clawcloud-phase7-release-gate.mjs"
  },
  "dependencies": {
